<Window
    x:Class="D4C3Jiami.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="D4C3 文件加密">

    <Border Padding="24">
        <Grid RowDefinitions="Auto,*">
            <StackPanel Spacing="4">
                <TextBlock Text="D4C3 文件加密" FontSize="28" FontWeight="SemiBold" />
                <TextBlock Text="本地离线处理文件，支持 1 到 3 层独立密码加密。" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>

            <TabView Grid.Row="1" Margin="0,24,0,0" IsAddTabButtonVisible="False">
                <TabViewItem Header="加密">
                    <ScrollViewer>
                        <Grid Margin="0,12,8,0" RowDefinitions="Auto,Auto,Auto,Auto,Auto" RowSpacing="18">
                            <Border
                                x:Name="EncryptDropZone"
                                MinHeight="120"
                                Padding="20"
                                BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                AllowDrop="True"
                                DragOver="EncryptDropZone_DragOver"
                                Drop="EncryptDropZone_Drop">
                                <StackPanel Spacing="10">
                                    <TextBlock Text="拖入要加密的文件" FontSize="18" FontWeight="SemiBold" />
                                    <TextBlock x:Name="EncryptFileText" Text="也可以点击下方按钮选择文件" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    <Button Content="选择文件" Click="PickEncryptFile_Click" HorizontalAlignment="Left" />
                                </StackPanel>
                            </Border>

                        <StackPanel Grid.Row="1" Spacing="8">
                            <TextBlock Text="加密层数" FontWeight="SemiBold" />
                            <NumberBox
                                x:Name="LayerCountBox"
                                Minimum="1"
                                Maximum="3"
                                SmallChange="1"
                                LargeChange="1"
                                SpinButtonPlacementMode="Inline"
                                Value="1"
                                ValueChanged="LayerCountBox_ValueChanged" />
                        </StackPanel>

                        <StackPanel Grid.Row="2" Spacing="12">
                            <TextBlock Text="每层加密方式和密码" FontWeight="SemiBold" />
                            <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                                <ComboBox x:Name="Layer1AlgorithmBox" Header="第 1 层算法" SelectedIndex="0" />
                                <PasswordBox x:Name="Layer1PasswordBox" Grid.Column="1" Header="第 1 层密码" />
                            </Grid>
                            <Grid x:Name="Layer2Panel" ColumnDefinitions="*,*" ColumnSpacing="12" Visibility="Collapsed">
                                <ComboBox x:Name="Layer2AlgorithmBox" Header="第 2 层算法" SelectedIndex="1" />
                                <PasswordBox x:Name="Layer2PasswordBox" Grid.Column="1" Header="第 2 层密码" />
                            </Grid>
                            <Grid x:Name="Layer3Panel" ColumnDefinitions="*,*" ColumnSpacing="12" Visibility="Collapsed">
                                <ComboBox x:Name="Layer3AlgorithmBox" Header="第 3 层算法" SelectedIndex="2" />
                                <PasswordBox x:Name="Layer3PasswordBox" Grid.Column="1" Header="第 3 层密码" />
                            </Grid>
                        </StackPanel>

                        <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="12">
                            <ComboBox x:Name="OutputExtensionBox" Header="输出扩展名" SelectedIndex="0" Width="180">
                                <ComboBoxItem Content=".enc" />
                                <ComboBoxItem Content=".jpg" />
                                <ComboBoxItem Content=".txt" />
                                <ComboBoxItem Content=".mp4" />
                            </ComboBox>
                            <Button Content="生成加密文件" Click="Encrypt_Click" VerticalAlignment="Bottom" />
                        </StackPanel>

                        <InfoBar
                            x:Name="EncryptInfoBar"
                            Grid.Row="4"
                            IsOpen="False"
                            IsClosable="True" />
                        </Grid>
                    </ScrollViewer>
                </TabViewItem>

                <TabViewItem Header="解密">
                    <ScrollViewer>
                        <Grid Margin="0,12,8,0" RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="18">
                            <Border
                                x:Name="DecryptDropZone"
                                MinHeight="120"
                                Padding="20"
                                BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                AllowDrop="True"
                                DragOver="DecryptDropZone_DragOver"
                                Drop="DecryptDropZone_Drop">
                                <StackPanel Spacing="10">
                                    <TextBlock Text="拖入加密文件" FontSize="18" FontWeight="SemiBold" />
                                    <TextBlock x:Name="DecryptFileText" Text="软件会读取文件头并显示加密层信息" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    <Button Content="选择加密文件" Click="PickDecryptFile_Click" HorizontalAlignment="Left" />
                                </StackPanel>
                            </Border>

                        <StackPanel Grid.Row="1" Spacing="8">
                            <TextBlock Text="文件信息" FontWeight="SemiBold" />
                            <TextBlock x:Name="DecryptHeaderText" Text="尚未读取文件信息" TextWrapping="Wrap" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </StackPanel>

                        <StackPanel Grid.Row="2" Spacing="12">
                            <PasswordBox x:Name="DecryptLayer1PasswordBox" Header="第 1 层密码" />
                            <PasswordBox x:Name="DecryptLayer2PasswordBox" Header="第 2 层密码" Visibility="Collapsed" />
                            <PasswordBox x:Name="DecryptLayer3PasswordBox" Header="第 3 层密码" Visibility="Collapsed" />
                            <Button Content="还原文件" Click="Decrypt_Click" HorizontalAlignment="Left" />
                        </StackPanel>

                        <InfoBar
                            x:Name="DecryptInfoBar"
                            Grid.Row="3"
                            IsOpen="False"
                            IsClosable="True" />
                        </Grid>
                    </ScrollViewer>
                </TabViewItem>
            </TabView>
        </Grid>
    </Border>
</Window>
